{
  "name": "aimhook",
  "version": "2.0.0",
  "description": "Privacy-preserving CoW protocol for Uniswap v4 using Fhenix CoFHE",
  "scripts": {
    "keeper": "ts-node script/KeeperBot.ts",
    "encrypt": "ts-node script/EncryptIntent.ts",
    "test": "forge test",
    "test:integration": "FOUNDRY_PROFILE=integration forge test --fork-url $ARB_SEPOLIA_RPC -vvv",
    "build": "forge build",
    "deploy": "forge script script/Deploy.s.sol --rpc-url $ARB_SEPOLIA_RPC --broadcast",
    "deploy:eth": "forge script script/Deploy.s.sol --rpc-url $ETH_SEPOLIA_RPC --broadcast",
    "init-pool": "forge script script/InitializePoolWithHook.s.sol --rpc-url $ARB_SEPOLIA_RPC --broadcast"
  },
  "dependencies": {
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "cofhejs": "^0.3.1",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@fhenixprotocol/cofhe-mock-contracts": "^0.3.0",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
